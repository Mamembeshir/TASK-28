# Copy this file to .env and fill in the values for local development outside Docker.
# When using docker-compose, these are already set in docker-compose.yml.

# Database connection string
DATABASE_URL=postgres://eduexchange:eduexchange@localhost:5432/eduexchange?sslmode=disable
DATABASE_URL_TEST=postgres://eduexchange:eduexchange@localhost:5432/eduexchange_test?sslmode=disable

# Server port
PORT=8080

# Session secret — change to a long random string in production
SESSION_SECRET=dev-session-secret-change-in-prod

# AES-256 encryption key — must be exactly 32 bytes in production
ENCRYPTION_KEY=dev-encryption-key-32-bytes!!!

# Timezone for scheduling (IANA timezone name)
FACILITY_TIMEZONE=America/New_York

# File storage paths (relative to working directory)
UPLOAD_PATH=data/uploads
EXPORT_PATH=data/exports
STATEMENT_PATH=data/statements
