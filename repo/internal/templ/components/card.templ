package components

templ Card(title string) {
	<div style="background:var(--surface-elevated);border:1px solid var(--border-default);border-radius:10px;box-shadow:var(--shadow-sm);">
		if title != "" {
			<div style="padding:16px 24px;border-bottom:1px solid var(--border-default);">
				<h3 style="font-size:1.125rem;font-weight:600;color:var(--text-primary);margin:0;">{ title }</h3>
			</div>
		}
		<div style="padding:16px 24px;">
			{ children... }
		</div>
	</div>
}
